const express = require('express'); const { createProxyMiddleware } = require('http-proxy-middleware'); const app = express(); const PORT = 8080; // 1. Set the site you want to "clone" or proxy const TARGET_URL = 'https://www.wikipedia.org'; // 2. Configure the proxy logic const proxyOptions = { target: TARGET_URL, changeOrigin: true, // Needed for virtual hosted sites autoRewrite: true, // Rewrites the location headers followRedirects: true, onProxyRes: function (proxyRes, req, res) { // This helps bypass some basic security headers that prevent framing delete proxyRes.headers['content-security-policy']; delete proxyRes.headers['x-frame-options']; }, }; // 3. Apply the proxy to all requests app.use('/', createProxyMiddleware(proxyOptions)); app.listen(PORT, () => { console.log(`Proxy is running at http://localhost:${PORT}`); });
